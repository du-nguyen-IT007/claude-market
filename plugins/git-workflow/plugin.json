{
  "name": "git-workflow",
  "version": "1.0.0",
  "description": "Git workflow automation",
  "author": { "name": "ECB Team" },
  "license": "MIT",
  "commands": [
    "./commands/commit.md",
    "./commands/pr.md",
    "./commands/changelog.md"
  ],
  "agents": [
    "./agents/git-agent.md"
  ],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_ROOT\" && git diff --stat HEAD 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
