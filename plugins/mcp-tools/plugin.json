{
  "name": "mcp-tools",
  "version": "1.0.0",
  "description": "MCP servers for filesystem, web fetch, and SQLite access",
  "author": { "name": "ECB Team" },
  "license": "MIT",
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "${CLAUDE_PROJECT_ROOT}"
      ]
    },
    "fetch": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-fetch"
      ]
    },
    "sqlite": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sqlite",
        "--db-path",
        "${CLAUDE_PLUGIN_DATA}/local.db"
      ]
    }
  }
}
